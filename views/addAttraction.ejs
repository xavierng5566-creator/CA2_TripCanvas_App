<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Add Attraction</title>
</head>


<body>
    <%- include('partials/header') %>

        <div class="container mt-5 mb-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Add New Attraction</h2>
                <p class="text-muted">Add a new destination for travellers to explore.</p>
            </div>

            <form action="/addAttraction" method="POST" enctype="multipart/form-data">
                <!-- Attraction Details -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning">
                        <h5 class="mb-0">Attraction Information</h5>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <!-- Name -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Attraction Name</label>
                                <input type="text" class="form-control" name="name" placeholder="Example: Gardens by the Bay" required>
                            </div>

                            <!-- Country -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Country</label>
                                <input type="text" class="form-control" name="country" placeholder="Singapore" required>
                            </div>

                            <!-- City -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">City</label>
                                <input type="text" class="form-control" name="city" placeholder="Singapore" required>
                            </div>
                            
                            <!-- Category -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Category</label>
                                <select class="form-select" name="category">
                                    <option value="Nature">Nature</option>
                                    <option value="Culture">Culture</option>
                                    <option value="Food">Food</option>
                                    <option value="Entertainment">Entertainment</option>
                                </select>
                            </div>

                            <!-- Description -->
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="description" rows="5" placeholder="Describe this attraction..." required></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Images -->

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Attraction Images</h5>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Main Image</label>
                                <input type="file" class="form-control" name="image1" accept="image/*" required>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Gallery Image 2</label>
                                <input type="file" class="form-control" name="image2" accept="image/*">
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Gallery Image 3</label>
                                <input type="file" class="form-control" name="image3" accept="image/*">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid">
                    <button class="btn btn-warning btn-lg">Add Attraction</button>
                </div>
            </form>
        </div>
</body>
</html>