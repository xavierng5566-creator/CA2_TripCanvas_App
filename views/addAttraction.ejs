<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Add Attraction</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title">Add New Attraction</h2>
            <p class="section-subtitle">Add a new destination for travellers to explore.</p>
        </div>

        <form action="/addAttraction" method="POST" enctype="multipart/form-data">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card large-panel h-100">
                        <div class="panel-header">
                            <h5 class="mb-1">Attraction Information</h5>
                        </div>
                        <div class="panel-body">
                            <div class="mb-3">
                                <label class="form-label">Attraction Name</label>
                                <input type="text" class="form-control" name="name" placeholder="Example: Gardens by the Bay" required>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Country</label>
                                    <input type="text" class="form-control" name="country" placeholder="Singapore" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">City</label>
                                    <input type="text" class="form-control" name="city" placeholder="Singapore" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Category</label>
                                <select class="form-select" name="category">
                                    <option value="Nature">Nature</option>
                                    <option value="Culture">Culture</option>
                                    <option value="Food">Food</option>
                                    <option value="Entertainment">Entertainment</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="description" rows="5" placeholder="Describe this attraction..." required></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card large-panel h-100">
                        <div class="panel-header">
                            <h5 class="mb-1">Attraction Images</h5>
                        </div>
                        <div class="panel-body">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label">Main Image</label>
                                    <input type="file" class="form-control" name="image1" accept="image/*" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Gallery Image 2</label>
                                    <input type="file" class="form-control" name="image2" accept="image/*">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Gallery Image 3</label>
                                    <input type="file" class="form-control" name="image3" accept="image/*">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 text-center">
                    <button class="btn btn-primary btn-lg px-5">Add Attraction</button>
                </div>
            </div>
        </form>
    </main>
</body>
</html>