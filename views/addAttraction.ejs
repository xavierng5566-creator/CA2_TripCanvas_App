<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Attraction Details</title>
</head>

<body>
    <%- include("partials/header") %>
        <div class="container mt-4">
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
            
            <div class="text-center mb-4">
                <h2>Attraction Details</h2>
            </div>

            <% if(attraction) { %>
                <div class="card mx-auto shadow" style="max-width:750px;">
                    <img src="/images/attractions/<%= attraction.image1 %>" class="card-img-top">

                    <div class="card-body">
                        <h2 class="text-center">
                            <%= attraction.name %>
                        </h2>

                        <div class="text-center mb-3">
                            <span class="badge bg-warning text-dark">
                                <%= attraction.category %>
                            </span>
                        </div>

                        <p>
                            <b>Location:</b>
                            <%= attraction.city %>, <%= attraction.country %>
                        </p>

                        <hr>

                        <h5>
                            About this attraction
                        </h5>

                        <p>
                            <%= attraction.description %>
                        </p>

                        <hr>

                        <h5>
                            Gallery
                        </h5>

                        <div class="row mt-3">
                            <div class="col">
                                <img src="/images/attractions/<%= attraction.image2 %>" class="img-fluid rounded">
                            </div>

                            <div class="col">
                                <img src="/images/attractions/<%= attraction.image3 %>" class="img-fluid rounded">
                            </div>
                        </div>
                    </div>
                </div>

                <% } else { %>
                    <p>
                        Attraction not found.
                    </p>

                    <% } %>
                        <div class="text-center mt-4">
                            <% if(user.role==="admin" ) { %>
                                <a href="/updateAttraction/<%= attraction.attractionId %>" class="btn btn-warning">
                                    Edit Attraction
                                </a>

                                <a href="/deleteAttraction/<%= attraction.attractionId %>" class="btn btn-danger">
                                    Delete
                                </a>

                                <% } %>
                                    <a href="/attractions" class="btn btn-secondary">
                                        Back
                                    </a>
                        </div>
        </div>
</body>
</html>