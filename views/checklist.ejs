<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Checklist</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title">Prepare everything before your adventure begins</h2>
            <p class="section-subtitle mx-auto" style="max-width: 720px;">Keep track of important items and never forget your essentials.</p>
        </div>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (trips.length === 0) { %>
            <div class="card large-panel text-center py-5">
                <h3>No trips yet</h3>
                <p class="text-muted">Create a trip first and use the checklist to pack with confidence.</p>
                <a href="/addTrip" class="btn btn-primary mt-3">Create a Trip</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% for (let i = 0; i < trips.length; i++) { %>
                    <div class="col-md-4">
                        <div class="card destination-card h-100 overflow-hidden">
                            <img src="/images/trips/<%= trips[i].image1 %>" class="card-img-top" alt="<%= trips[i].tripName %>">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="card-title"><%= trips[i].tripName %></h5>
                                    <p class="text-muted mb-3"><%= trips[i].city %>, <%= trips[i].country %></p>
                                </div>
                                <a href="/checklist/<%= trips[i].tripId %>" class="btn btn-primary mt-3">View Checklist</a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</body>

</html>
