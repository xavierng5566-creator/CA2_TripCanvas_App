<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Admin Dashboard</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="mb-5">
            <p class="text-uppercase text-muted mb-2">Administrator</p>
            <h2 class="section-title">TripCanvas Admin Dashboard</h2>
            <p class="section-subtitle">Monitor the platform with a clean overview of trips, attractions and registered users.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card large-panel text-center py-4">
                    <p class="panel-stat mb-2">Total Trips</p>
                    <p class="panel-value mb-0"><%= totalTrips %></p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card large-panel text-center py-4">
                    <p class="panel-stat mb-2">Total Attractions</p>
                    <p class="panel-value mb-0"><%= totalAttractions %></p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card large-panel text-center py-4">
                    <p class="panel-stat mb-2">Total Users</p>
                    <p class="panel-value mb-0"><%= totalUsers %></p>
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex flex-wrap gap-3">
            <a href="/attractions" class="btn btn-primary">Manage Attractions</a>
            <a href="/addAttraction" class="btn btn-secondary">Add Attraction</a>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>
    </main>
</body>

</html>