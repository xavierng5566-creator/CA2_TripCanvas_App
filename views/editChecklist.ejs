<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Edit Checklist Item</title>
</head>

<body>
    <%- include('partials/header') %>

    <div class="container mt-4">
        <h2 class="text-center mb-4">Edit Checklist Item</h2>
        <p class="text-center text-muted">Trip: <%= item.tripName %></p>

        <form action="/checklist/edit/<%= item.checklistId %>" method="POST" class="mx-auto" style="max-width:500px;">
            <input type="hidden" name="tripId" value="<%= item.tripId %>">

            <div class="mb-3">
                <label class="form-label">Item Name</label>
                <input type="text" class="form-control" name="itemName" value="<%= item.itemName %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" name="category" required>
                    <% categories.forEach(function(cat) { %>
                        <option value="<%= cat %>" <%= item.category === cat ? 'selected' : '' %>><%= cat %></option>
                    <% }); %>
                </select>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="isPacked" name="isPacked"
                    <%= item.isPacked ? 'checked' : '' %> required>
                <label class="form-check-label" for="isPacked">Packed</label>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/checklist/<%= item.tripId %>" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</body>

</html>
