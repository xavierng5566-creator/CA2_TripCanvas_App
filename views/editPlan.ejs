<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Edit Plan | TripCanvas</title>
</head>
<body class="bg-light">
    <%- include("partials/header") %>

    <main class="container mt-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Edit Plan</h2>
                <p class="text-muted mb-0"><%= trip.tripName %> &bull; <%= trip.city %>, <%= trip.country %></p>
            </div>
            <a href="/planner/<%= trip.tripId %>" class="btn btn-outline-secondary">Back to Planner</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form action="/planner/<%= trip.tripId %>/edit/<%= item.id %>" method="post">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="dayNumber" class="form-label">Day</label>
                            <select id="dayNumber" class="form-select" name="dayNumber" required>
                                <% days.forEach((day) => { %>
                                    <option value="<%= day.dayNumber %>" <%= Number(item.dayNumber) === Number(day.dayNumber) ? 'selected' : '' %>>
                                        Day <%= day.dayNumber %> of <%= days.length %> - <%= day.label %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label for="title" class="form-label">Plan Title</label>
                            <input id="title" type="text" class="form-control" name="title" value="<%= item.title %>" required maxlength="255">
                        </div>

                        <div class="col-md-4">
                            <label for="sortOrder" class="form-label">Order in this day</label>
                            <input id="sortOrder" type="number" class="form-control" name="sortOrder" value="<%= item.sortOrder || 1 %>" min="1" required>
                        </div>

                        <div class="col-md-4">
                            <label for="timeSlot" class="form-label">Time</label>
                            <input id="timeSlot" type="text" class="form-control" name="timeSlot" value="<%= item.timeSlot || '' %>" placeholder="Morning / 10:30 AM" required>
                        </div>

                        <div class="col-12">
                            <label for="description" class="form-label">Description</label>
                            <textarea id="description" class="form-control" name="description" rows="5" placeholder="Add details about this activity" required><%= item.description || '' %></textarea>
                        </div>

                        <div class="col-12 d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a href="/planner/<%= trip.tripId %>" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
