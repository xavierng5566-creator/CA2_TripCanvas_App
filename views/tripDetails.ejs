<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>

<body>
    <%- include("partials/header") %>

    <main class="container py-5">
        <% if (trip) { %>
            <div class="row g-4 align-items-center mb-4">
                <div class="col-lg-7">
                    <div class="large-panel overflow-hidden">
                        <img src="/images/trips/<%= trip.image1 %>" alt="Trip hero" class="w-100">
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="large-panel">
                        <div class="panel-header">
                            <h2 class="mb-2"><%= trip.tripName %></h2>
                            <p class="text-muted mb-0"><%= trip.city %>, <%= trip.country %></p>
                        </div>
                        <div class="panel-body">
                            <div class="row gy-3">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">Travel Dates</h6>
                                            <p class="mb-0 text-muted"><%= trip.startDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %> - <%= trip.endDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                        </div>
                                        <span class="status-pill <%= trip.status.toLowerCase() === 'planning' ? 'status-planning' : trip.status.toLowerCase() === 'upcoming' ? 'status-upcoming' : 'status-completed' %>"><%= trip.status %></span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <h6 class="mb-1">Budget</h6>
                                    <p class="mb-0 text-muted">$<%= trip.budget.toFixed(2) %></p>
                                </div>
                                <div class="col-12">
                                    <h6 class="mb-1">Gallery</h6>
                                    <div class="row gx-2">
                                        <div class="col-6">
                                            <img src="/images/trips/<%= trip.image2 %>" class="img-fluid rounded" alt="Trip image 2">
                                        </div>
                                        <div class="col-6">
                                            <img src="/images/trips/<%= trip.image3 %>" class="img-fluid rounded" alt="Trip image 3">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 justify-content-center">
                <a href="/planner/<%= trip.tripId %>" class="btn btn-primary btn-lg">View Planner</a>
                <a href="/checklist/<%= trip.tripId %>" class="btn btn-secondary btn-lg">View Checklist</a>
                <a href="/updateTrip/<%= trip.tripId %>" class="btn btn-warning btn-lg">Edit Trip</a>
                <a href="/deleteTrip/<%= trip.tripId %>" class="btn btn-danger btn-lg">Delete</a>
            </div>
        <% } else { %>
            <div class="card large-panel text-center py-5">
                <h3>No trip found.</h3>
            </div>
        <% } %>
    </main>
</body>

</html>