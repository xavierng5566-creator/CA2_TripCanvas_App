<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>

<body>
    <%- include("partials/header") %>

        <div class="container mt-4">
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

            <div class="text-center mb-4">
                <h2>Trip Details</h2>
            </div>

            <% if (trip) { %>
                <div class="card mx-auto shadow" style="max-width:700px;">
                    <img src="/images/trips/<%= trip.image1 %>" class="card-img-top">
                    <div class="card-body">
                        <h3 class="text-center">
                            <%= trip.tripName %>
                        </h3>

                        <p><b>Destination:</b>
                            <%= trip.city %>, <%= trip.country %>
                        </p>

                        <p><b>Travel Dates:</b>
                            <%= trip.startDate.toLocaleDateString('en-GB', { day: 'numeric' , month: 'short' ,
                                year: 'numeric' }) %> -

                                <%= trip.endDate.toLocaleDateString('en-GB', { day: 'numeric' , month: 'short' ,
                                    year: 'numeric' }) %>
                        </p>

                        <p><b>Budget:</b> $<%= trip.budget.toFixed(2) %>
                        </p>

                        <p><b>Status:</b>
                            <%= trip.status %>
                        </p>

                        <hr>

                        <div class="row text-center">
                            <div class="col">
                                <img src="/images/trips/<%= trip.image2 %>" class="img-fluid rounded">
                            </div>

                            <div class="col">
                                <img src="/images/trips/<%= trip.image3 %>" class="img-fluid rounded">
                            </div>
                        </div>
                    </div>
                </div>

                <% } else { %>
                    <p>No trip found.</p>
                    <% } %>
                        <div class="text-center mt-4">
                            <a href="/planner/<%= trip.tripId %>" class="btn btn-primary">View Planner</a>
                            <a href="/updateTrip/<%= trip.tripId %>" class="btn btn-warning">Edit Trip</a>
                            <a href="/deleteTrip/<%= trip.tripId %>" class="btn btn-danger">Delete</a>
                            <a href="/trips" class="btn btn-secondary">Back</a>
                        </div>
        </div>
</body>

</html>