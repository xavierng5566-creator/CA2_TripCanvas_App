<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Checklist</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5 mb-5">
        <div class="mb-4">
            <a href="/checklist" class="text-decoration-none text-secondary">&laquo; Back to My Checklists</a>
        </div>

        <div class="text-center mb-4">
            <h2 class="section-title">Checklist for <%= trip.tripName %></h2>
            <p class="section-subtitle"><%= trip.city %>, <%= trip.country %></p>
        </div>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="card large-panel mb-4">
            <div class="panel-header">
                <h5 class="mb-0">Add Checklist Item</h5>
            </div>
            <div class="panel-body">
                <form action="/checklist/<%= trip.tripId %>/add" method="POST" class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Item Name</label>
                        <input type="text" class="form-control" name="itemName" placeholder="Example: Passport" required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Category</label>
                        <select class="form-select" name="category" required>
                            <option value="" disabled selected>Select a category</option>
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat %>"><%= cat %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-primary">+ Add Item</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Checklist Items -->
        <% if (items.length === 0) { %>
            <div class="card large-panel text-center py-5">
                <h4 class="mb-2">No checklist items yet.</h4>
                <p class="text-muted mb-0">Add one above to start packing for your trip.</p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-borderless align-middle bg-white shadow-sm rounded-4 overflow-hidden">
                    <thead class="table-light">
                        <tr>
                            <th style="width:70px;">Packed</th>
                            <th>Item Name</th>
                            <th>Category</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let i = 0; i < items.length; i++) { %>
                            <tr class="<%= items[i].isPacked ? 'checklist-item-checked' : '' %>">
                                <td>
                                    <input type="checkbox" class="form-check-input"
                                        onchange="toggleItem(<%= trip.tripId %>, <%= items[i].checklistId %>, this)"
                                        <%= items[i].isPacked ? 'checked' : '' %>>
                                </td>
                                <td id="itemName-<%= items[i].checklistId %>"><%= items[i].itemName %></td>
                                <td><span class="checklist-item-capsule"><%= items[i].category %></span></td>
                                <td>
                                    <a href="/checklist/edit/<%= items[i].checklistId %>" class="btn btn-sm btn-secondary">Edit</a>
                                    <a href="/checklist/delete/<%= trip.tripId %>/<%= items[i].checklistId %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this checklist item?');">Delete</a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <div class="text-center mt-4">
            <a href="/trip/<%= trip.tripId %>" class="btn btn-secondary">Back to Trip</a>
        </div>
    </main>

    <script>
        // Toggles "packed" status in the background (no page reload).
        function toggleItem(tripId, checklistId, checkbox) {
            fetch(`/checklist/${tripId}/toggle/${checklistId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) throw new Error('Update failed');

                    const nameCell = document.getElementById('itemName-' + checklistId);
                    if (data.isPacked) {
                        nameCell.classList.add('text-decoration-line-through', 'text-muted');
                    } else {
                        nameCell.classList.remove('text-decoration-line-through', 'text-muted');
                    }
                })
                .catch(() => {
                    checkbox.checked = !checkbox.checked; // revert the checkbox
                    alert('Could not update item. Please try again.');
                });
        }
    </script>
</body>

</html>
