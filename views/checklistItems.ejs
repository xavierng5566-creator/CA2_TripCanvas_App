<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Checklist</title>
</head>

<body>
    <%- include('partials/header') %>

    <div class="container mt-4 mb-5">
        <p><a href="/checklist">&laquo; Back to My Checklists</a></p>

        <div class="text-center mb-4">
            <h2>Checklist for <%= trip.tripName %></h2>
            <p class="text-muted"><%= trip.city %>, <%= trip.country %></p>
        </div>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <!-- Add Item Form -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Add Checklist Item</h5>
            </div>
            <div class="card-body">
                <form action="/checklist/<%= trip.tripId %>/add" method="POST" class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Item Name</label>
                        <input type="text" class="form-control" name="itemName" placeholder="Example: Passport" required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Category</label>
                        <select class="form-select" name="category" required>
                            <option value="" disabled selected>Select a category</option>
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat %>"><%= cat %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-success w-100">+ Add Item</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Checklist Items -->
        <% if (items.length === 0) { %>
            <p class="text-center text-muted">No checklist items yet. Add one above to get started.</p>
        <% } else { %>
            <table class="table table-bordered align-middle bg-white shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">Packed</th>
                        <th>Item Name</th>
                        <th>Category</th>
                        <th style="width:160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let i = 0; i < items.length; i++) { %>
                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input"
                                    onchange="toggleItem(<%= trip.tripId %>, <%= items[i].checklistId %>, this)"
                                    <%= items[i].isPacked ? 'checked' : '' %>>
                            </td>
                            <td id="itemName-<%= items[i].checklistId %>"
                                class="<%= items[i].isPacked ? 'text-decoration-line-through text-muted' : '' %>">
                                <%= items[i].itemName %>
                            </td>
                            <td><span class="badge bg-secondary"><%= items[i].category %></span></td>
                            <td>
                                <a href="/checklist/edit/<%= items[i].checklistId %>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/checklist/delete/<%= trip.tripId %>/<%= items[i].checklistId %>"
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('Delete this checklist item?');">Delete</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        <% } %>

        <div class="text-center mt-4">
            <a href="/trip/<%= trip.tripId %>" class="btn btn-secondary">Back to Trip</a>
        </div>
    </div>

    <script>
        // Toggles "packed" status in the background (no page reload).
        function toggleItem(tripId, checklistId, checkbox) {
            fetch(`/checklist/${tripId}/toggle/${checklistId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) throw new Error('Update failed');

                    const nameCell = document.getElementById('itemName-' + checklistId);
                    if (data.isPacked) {
                        nameCell.classList.add('text-decoration-line-through', 'text-muted');
                    } else {
                        nameCell.classList.remove('text-decoration-line-through', 'text-muted');
                    }
                })
                .catch(() => {
                    checkbox.checked = !checkbox.checked; // revert the checkbox
                    alert('Could not update item. Please try again.');
                });
        }
    </script>
</body>

</html>
