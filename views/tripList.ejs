<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>


<body>
    <!-- Navbar -->
    <%- include('partials/header') %>

    <div class="container mt-4">
        <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

        <div class="text-center">
            <h2>My Travel Plans</h2>
        </div>

        <br>

        <div class="text-end mb-3">
    <a href="/addTrip" class="btn btn-success">+ Create New Trip</a>
</div>

<!-- Search / Filter / Sort -->
<form method="GET" action="/trips" class="card shadow-sm p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Search</label>
            <input type="text" name="search" class="form-control"
                placeholder="Trip name, city or country..." value="<%= query.search %>">
        </div>

        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
                <option value="">All</option>
                <option value="Planning" <%= query.status==='Planning' ? 'selected' : '' %>>Planning</option>
                <option value="Upcoming" <%= query.status==='Upcoming' ? 'selected' : '' %>>Upcoming</option>
                <option value="Completed" <%= query.status==='Completed' ? 'selected' : '' %>>Completed</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Sort By</label>
            <select name="sort" class="form-select">
                <option value="date_asc" <%= query.sort==='date_asc' ? 'selected' : '' %>>Date (Earliest)</option>
                <option value="date_desc" <%= query.sort==='date_desc' ? 'selected' : '' %>>Date (Latest)</option>
                <option value="name_asc" <%= query.sort==='name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
                <option value="name_desc" <%= query.sort==='name_desc' ? 'selected' : '' %>>Name (Z-A)</option>
                <option value="budget_asc" <%= query.sort==='budget_asc' ? 'selected' : '' %>>Budget (Low-High)</option>
                <option value="budget_desc" <%= query.sort==='budget_desc' ? 'selected' : '' %>>Budget (High-Low)</option>
            </select>
        </div>

        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
            <a href="/trips" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </div>
</form>

<% if (trips.length===0) { %>
    <div class="alert alert-info">
        No trips match your search/filter. Try adjusting your criteria, or create a new trip.
    </div>
<% } %>

<div class="row">
    <% for(let i = 0; i < trips.length; i++) { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm">
                        <!-- Trip Image -->
                        <img src="/images/trips/<%= trips[i].image1 %>" class="card-img-top" height="220">

                        <div class="card-body">
                            <!-- Trip Name -->
                            <h5 class="card-title">
                                <a href="/trip/<%= trips[i].tripId %>">
                                    <%= trips[i].tripName %>
                                </a>
                            </h5>

                            <p class="card-text">
                                <%= trips[i].city %>, <%= trips[i].country %>

                                <br>

                                Dates:
                                <%= trips[i].startDate.toLocaleDateString('en-GB',
                                    { day: 'numeric', month: 'short', year: 'numeric' }
                                ) %> -
                                <%= trips[i].endDate.toLocaleDateString('en-GB',
                                    { day: 'numeric', month: 'short', year: 'numeric' }
                                ) %>
                                
                                <br>
                                Budget:
                                $<%= trips[i].budget.toFixed(2) %>

                                <br>

                                Status:
                                <%= trips[i].status %>
                            </p>

                            <a href="/trip/<%= trips[i].tripId %>" class="btn btn-primary">View Trip</a>
                            <a href="/updateTrip/<%= trips[i].tripId %>" class="btn btn-warning">Edit</a>
                            <a href="/deleteTrip/<%= trips[i].tripId %>" class="btn btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>