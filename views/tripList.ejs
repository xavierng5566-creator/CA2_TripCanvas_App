<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>


<body>
    <!-- Navbar -->
    <%- include('partials/header') %>

    <div class="container mt-4">
        <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

        <div class="text-center">
            <h2>My Travel Plans</h2>
        </div>

        <br>

        <div class="text-end mb-3">
            <a href="/addTrip" class="btn btn-success">+ Create New Trip</a>
        </div>

        <div class="row">
            <% for(let i = 0; i < trips.length; i++) { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm">
                        <!-- Trip Image -->
                        <img src="/images/trips/<%= trips[i].image1 %>" class="card-img-top" height="220">

                        <div class="card-body">
                            <!-- Trip Name -->
                            <h5 class="card-title">
                                <a href="/trip/<%= trips[i].tripId %>">
                                    <%= trips[i].tripName %>
                                </a>
                            </h5>

                            <p class="card-text">
                                <%= trips[i].city %>, <%= trips[i].country %>

                                <br>

                                Dates:
                                <%= trips[i].startDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %> - <%= trips[i].endDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>

                                <br>
                                Budget:
                                $<%= trips[i].budget.toFixed(2) %>

                                <br>

                                Status:
                                <%= trips[i].status %>
                            </p>

                            <a href="/trip/<%= trips[i].tripId %>" class="btn btn-primary">View Trip</a>
                            <a href="/updateTrip/<%= trips[i].tripId %>" class="btn btn-warning">Edit</a>
                            <a href="/deleteTrip/<%= trips[i].tripId %>" class="btn btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>