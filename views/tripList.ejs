<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <section class="mb-5 text-center">
            <p class="text-uppercase text-muted mb-2">Welcome back, <%= user.username %></p>
            <h2 class="section-title">Your adventures start here.</h2>
            <p class="section-subtitle mx-auto" style="max-width: 680px;">Create, organise and track every journey with TripCanvas.</p>
            <div class="mt-4">
                <a href="/addTrip" class="btn btn-primary btn-lg me-2">Create New Trip</a>
                <a href="/attractions" class="btn btn-secondary btn-lg">Discover Attractions</a>
            </div>
        </section>

        <section class="card shadow-sm p-4 mb-4 bg-soft-blue">
            <form method="GET" action="/trips" class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label fw-semibold">Search trips</label>
                    <input type="text" name="search" class="form-control" placeholder="Trip name, city or country..." value="<%= query.search %>">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All</option>
                        <option value="Planning" <%= query.status==='Planning' ? 'selected' : '' %>>Planning</option>
                        <option value="Upcoming" <%= query.status==='Upcoming' ? 'selected' : '' %>>Upcoming</option>
                        <option value="Completed" <%= query.status==='Completed' ? 'selected' : '' %>>Completed</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Sort by</label>
                    <select name="sort" class="form-select">
                        <option value="date_asc" <%= query.sort==='date_asc' ? 'selected' : '' %>>Date (Earliest)</option>
                        <option value="date_desc" <%= query.sort==='date_desc' ? 'selected' : '' %>>Date (Latest)</option>
                        <option value="name_asc" <%= query.sort==='name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
                        <option value="name_desc" <%= query.sort==='name_desc' ? 'selected' : '' %>>Name (Z-A)</option>
                        <option value="budget_asc" <%= query.sort==='budget_asc' ? 'selected' : '' %>>Budget (Low-High)</option>
                        <option value="budget_desc" <%= query.sort==='budget_desc' ? 'selected' : '' %>>Budget (High-Low)</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a href="/trips" class="btn btn-secondary">Reset</a>
                </div>
            </form>
        </section>

        <% if (trips.length===0) { %>
            <div class="card large-panel text-center py-5">
                <h3>No trips yet</h3>
                <p class="text-muted">Start your first itinerary and keep your next adventure organised with TripCanvas.</p>
                <a href="/addTrip" class="btn btn-primary mt-3">Create Your First Trip</a>
            </div>
        <% } %>

        <div class="row g-4">
            <% for(let i = 0; i < trips.length; i++) { %>
                <div class="col-lg-4">
                    <div class="card destination-card overflow-hidden h-100">
                        <img src="/images/trips/<%= trips[i].image1 %>" alt="Trip image">
                        <div class="card-body position-relative">
                            <div class="mb-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="card-title mb-1"><a href="/trip/<%= trips[i].tripId %>" class="stretched-link text-dark text-decoration-none"><%= trips[i].tripName %></a></h5>
                                    <p class="text-muted mb-0"><%= trips[i].city %>, <%= trips[i].country %></p>
                                </div>
                                <span class="status-pill <%= trips[i].status.toLowerCase() === 'planning' ? 'status-planning' : trips[i].status.toLowerCase() === 'upcoming' ? 'status-upcoming' : 'status-completed' %>"><%= trips[i].status %></span>
                            </div>

                            <div class="d-flex justify-content-between text-muted small mb-3">
                                <span><strong>Dates</strong><br><%= trips[i].startDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) %> - <%= trips[i].endDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) %></span>
                                <span><strong>Budget</strong><br>$<%= trips[i].budget.toFixed(2) %></span>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <a href="/trip/<%= trips[i].tripId %>" class="btn btn-sm btn-primary">View</a>
                                <a href="/updateTrip/<%= trips[i].tripId %>" class="btn btn-sm btn-secondary">Edit</a>
                                <a href="/deleteTrip/<%= trips[i].tripId %>" class="btn btn-sm btn-warning">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>