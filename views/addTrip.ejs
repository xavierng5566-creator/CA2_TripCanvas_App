<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Add a Trip</title>
</head>

<body>
    <!-- Navbar -->
    <%- include('partials/header') %>

    <div class="container mt-5 mb-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Create New Trip</h2>
            <p class="text-muted">Plan your next adventure with TripCanvas</p>
        </div>

        <form action="/addTrip" method="POST" enctype="multipart/form-data">
            <!-- Trip Details Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Trip Details</h5>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Trip Name -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Trip Name</label>
                            <input type="text" class="form-control" name="tripName" placeholder="Example: Japan Adventure" required>
                        </div>

                        <!-- Country -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Country</label>
                            <input type="text" class="form-control" name="country" placeholder="Japan" required>
                        </div>

                        <!-- City -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">City</label>
                            <input type="text" class="form-control" name="city" placeholder="Tokyo" required>
                        </div>

                        <!-- Budget -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Budget ($)</label>
                            <input type="number" class="form-control" name="budget" min="0" step="0.01" placeholder="2000" required>
                        </div>

                        <!-- Start Date -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-control" name="startDate" required>
                        </div>

                        <!-- End Date -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control" name="endDate" required>
                        </div>

                        <!-- Status -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Trip Status</label>

                            <select class="form-select" name="status">
                                <option value="Planning">Planning</option>
                                <option value="Upcoming">Upcoming</option>
                                <option value="Completed">Completed</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Images Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Trip Images</h5>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Image 1 -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gallery Image 1</label>
                            <input type="file" class="form-control" name="image1" accept="image/*">
                        </div>
                        
                        <!-- Image 2 -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gallery Image 2</label>
                            <input type="file" class="form-control" name="image2" accept="image/*">
                        </div>

                        <!-- Image 3 -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gallery Image 3</label>
                            <input type="file" class="form-control" name="image3" accept="image/*">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit -->
            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Create Trip</button>
            </div>
        </form>
    </div>
</body>
</html>