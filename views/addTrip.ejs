<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Add a Trip</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title">Create New Trip</h2>
            <p class="section-subtitle">Start planning your next journey with an easy trip setup experience.</p>
        </div>

        <form action="/addTrip" method="POST" enctype="multipart/form-data">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card large-panel h-100">
                        <div class="panel-header">
                            <h5 class="mb-1">Destination Details</h5>
                            <p class="text-muted mb-0">Where are you going?</p>
                        </div>
                        <div class="panel-body">
                            <div class="mb-3">
                                <label class="form-label">Trip Name</label>
                                <input type="text" class="form-control" name="tripName" placeholder="Example: Japan Adventure" required>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Country</label>
                                    <input type="text" class="form-control" name="country" placeholder="Japan" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">City</label>
                                    <input type="text" class="form-control" name="city" placeholder="Tokyo" required>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card large-panel h-100">
                        <div class="panel-header">
                            <h5 class="mb-1">Travel Schedule</h5>
                            <p class="text-muted mb-0">Set the dates and status of your trip.</p>
                        </div>
                        <div class="panel-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Start Date</label>
                                    <input type="date" class="form-control" name="startDate" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">End Date</label>
                                    <input type="date" class="form-control" name="endDate" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Budget ($)</label>
                                    <input type="number" class="form-control" name="budget" min="0" step="0.01" placeholder="2000" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Trip Status</label>
                                    <select class="form-select" name="status">
                                        <option value="Planning">Planning</option>
                                        <option value="Upcoming">Upcoming</option>
                                        <option value="Completed">Completed</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card large-panel">
                        <div class="panel-header">
                            <h5 class="mb-1">Trip Images</h5>
                            <p class="text-muted mb-0">Add visuals that bring your trip to life.</p>
                        </div>
                        <div class="panel-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Gallery Image 1</label>
                                    <input type="file" class="form-control" name="image1" accept="image/*" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Gallery Image 2</label>
                                    <input type="file" class="form-control" name="image2" accept="image/*">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Gallery Image 3</label>
                                    <input type="file" class="form-control" name="image3" accept="image/*">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 text-center mt-2">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Create Trip</button>
                </div>
            </div>
        </form>
    </main>
</body>
</html>