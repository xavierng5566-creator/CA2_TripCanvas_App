<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Attractions</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
            <div>
                <p class="text-uppercase text-muted mb-2">Discover destinations</p>
                <h2 class="section-title">Explore attractions curated for your journey</h2>
            </div>
            <% if(user.role === "admin") { %>
                <a href="/addAttraction" class="btn btn-primary">+ Add Attraction</a>
            <% } %>
        </div>

        <section class="card shadow-sm p-4 mb-4 bg-soft-blue">
            <form method="GET" action="/attractions" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text" name="search" class="form-control" placeholder="Name, city or country..." value="<%= query.search %>">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat %>" <%= query.category===cat ? 'selected' : '' %>><%= cat %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Country</label>
                    <select name="country" class="form-select">
                        <option value="">All</option>
                        <% countries.forEach(function(c) { %>
                            <option value="<%= c %>" <%= query.country===c ? 'selected' : '' %>><%= c %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Sort By</label>
                    <select name="sort" class="form-select">
                        <option value="name_asc" <%= query.sort==='name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
                        <option value="name_desc" <%= query.sort==='name_desc' ? 'selected' : '' %>>Name (Z-A)</option>
                        <option value="category_asc" <%= query.sort==='category_asc' ? 'selected' : '' %>>Category</option>
                        <option value="country_asc" <%= query.sort==='country_asc' ? 'selected' : '' %>>Country</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a href="/attractions" class="btn btn-secondary">Reset</a>
                </div>
            </form>
        </section>

        <% if (attractions.length===0) { %>
            <div class="card large-panel text-center py-5">
                <h3>No attractions match your search/filter</h3>
                <p class="text-muted">Try a broader location or category to discover new travel experiences.</p>
            </div>
        <% } %>

        <div class="row g-4">
            <% for(let i=0; i < attractions.length; i++) { %>
                <div class="col-lg-4">
                    <div class="card attraction-card h-100">
                        <img src="/images/attractions/<%= attractions[i].image1 %>" alt="<%= attractions[i].name %>" class="card-img-top">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title mb-2"><a href="/attraction/<%= attractions[i].attractionId %>" class="text-dark text-decoration-none"><%= attractions[i].name %></a></h5>
                                <p class="mb-2 text-muted"><strong><%= attractions[i].city %>, <%= attractions[i].country %></strong></p>
                                <span class="badge bg-primary text-white mb-3"><%= attractions[i].category %></span>
                                <p class="card-text text-muted"><%= attractions[i].description.length > 90 ? attractions[i].description.substring(0, 90) + '...' : attractions[i].description %></p>
                            </div>
                            <div class="mt-3 d-flex flex-wrap gap-2">
                                <a href="/attraction/<%= attractions[i].attractionId %>" class="btn btn-primary btn-sm">View Details</a>
                                <% if(user.role==="admin") { %>
                                    <a href="/updateAttraction/<%= attractions[i].attractionId %>" class="btn btn-secondary btn-sm">Edit</a>
                                    <a href="/deleteAttraction/<%= attractions[i].attractionId %>" class="btn btn-warning btn-sm">Delete</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>