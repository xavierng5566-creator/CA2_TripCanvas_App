<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Attractions</title>
</head>


<body>
    <%- include('partials/header') %>

        <div class="container mt-4">
            <p>
                Welcome, <%= user.username %> (<%= user.role %>)
            </p>

            <div class="text-center">
                <h2>Explore Attractions</h2>
            </div>

            <br>

            <% if(user.role==="admin" ) { %>
                <div class="text-end mb-3">
                    <a href="/addAttraction" class="btn btn-success">
                        + Add Attraction
                    </a>
                </div>

                <% } %>
                    <div class="row">
                        <% for(let i=0; i < attractions.length; i++) { %>
                            <div class="col-md-4 mb-4">
                                <div class="card shadow-sm">
                                    <img src="/images/attractions/<%= attractions[i].image1 %>" class="card-img-top" height="220">

                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <a href="/attraction/<%= attractions[i].attractionId %>">
                                                <%= attractions[i].name %>
                                            </a>
                                        </h5>

                                        <p class="card-text">
                                            Location: <%= attractions[i].city %>, <%= attractions[i].country %>

                                            <br>

                                            Category: <%= attractions[i].category %>
                                        </p>

                                        <a href="/attraction/<%= attractions[i].attractionId %>" class="btn btn-primary">
                                            View Details
                                        </a>

                                        <% if(user.role==="admin" ) { %>
                                            <a href="/updateAttraction/<%= attractions[i].attractionId %>" class="btn btn-warning">Edit</a>
                                            <a href="/deleteAttraction/<%= attractions[i].attractionId %>" class="btn btn-danger">Delete</a>
                                        
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
        </div>