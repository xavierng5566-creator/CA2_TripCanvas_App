<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Update Attraction</title>
</head>


<body>
    <%- include('partials/header') %>
        <div class="container mt-4">
            <h2 class="text-center mb-4">Update Attraction</h2>

            <% if (attraction) { %>
                <form action="/updateAttraction/<%= attraction.attractionId %>" method="POST" enctype="multipart/form-data" class="mx-auto" style="max-width:500px;">

                    <!-- Name -->
                    <div class="mb-3">
                        <label class="form-label">Attraction Name</label>
                        <input type="text" class="form-control" name="name" value="<%= attraction.name %>" required>
                    </div>

                    <!-- Country -->
                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <input type="text" class="form-control" name="country" value="<%= attraction.country %>" required>
                    </div>

                    <!-- City -->
                    <div class="mb-3">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" name="city" value="<%= attraction.city %>" required>
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label class="form-label">Category</label>

                        <select class="form-select" name="category">
                            <option value="Nature" <%=attraction.category==="Nature" ? "selected" : "" %>>Nature</option>
                            <option value="Culture" <%=attraction.category==="Culture" ? "selected" : "" %>>Culture</option>
                            <option value="Food" <%=attraction.category==="Food" ? "selected" : "" %>>Food</option>
                            <option value="Entertainment" <%=attraction.category==="Entertainment" ? "selected" : "" %>>Entertainment</option>
                        </select>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="5" required><%= attraction.description %></textarea>
                    </div>

                    <!-- Current Images -->
                    <div class="mb-3">
                        <label class="form-label">Current Images</label>
                        <input type="hidden" name="currentImage1" value="<%= attraction.image1 %>">
                        <input type="hidden" name="currentImage2" value="<%= attraction.image2 %>">
                        <input type="hidden" name="currentImage3" value="<%= attraction.image3 %>">

                        <div class="row">
                            <% if(attraction.image1) { %>
                                <div class="col">
                                    <img src="/images/attractions/<%= attraction.image1 %>" class="img-thumbnail" width="120">
                                </div>
                            <% } %>
                                <% if(attraction.image2) { %>
                                    <div class="col">
                                        <img src="/images/attractions/<%= attraction.image2 %>" class="img-thumbnail" width="120">
                                    </div>
                            <% } %>
                                <% if(attraction.image3) { %>
                                    <div class="col">
                                        <img src="/images/attractions/<%= attraction.image3 %>" class="img-thumbnail" width="120">
                                    </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Upload New Images -->
                    <div class="mb-4">
                        <label class="form-label">
                            Upload New Images
                        </label>

                        <input type="file" class="form-control" name="image1" accept="image/*">
                        <input type="file" class="form-control mt-2" name="image2" accept="image/*">
                        <input type="file" class="form-control mt-2" name="image3" accept="image/*">
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning">
                            Update Attraction
                        </button>

                        <a href="/attractions" class="btn btn-secondary">
                            Back
                        </a>
                    </div>
                </form>

                <% } else { %>
                    <p class="text-center">
                        No attraction found.
                    </p>
                <% } %>
        </div>

</body>
</html>