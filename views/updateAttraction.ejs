<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Update Attraction</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title">Update Attraction</h2>
            <p class="section-subtitle">Refresh the destination details and gallery to keep listings inspiring.</p>
        </div>

        <% if (attraction) { %>
            <form action="/updateAttraction/<%= attraction.attractionId %>" method="POST" enctype="multipart/form-data">
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card large-panel h-100">
                            <div class="panel-header">
                                <h5 class="mb-1">Attraction Details</h5>
                            </div>
                            <div class="panel-body">
                                <div class="mb-3">
                                    <label class="form-label">Attraction Name</label>
                                    <input type="text" class="form-control" name="name" value="<%= attraction.name %>" required>
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Country</label>
                                        <input type="text" class="form-control" name="country" value="<%= attraction.country %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" name="city" value="<%= attraction.city %>" required>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Category</label>
                                    <select class="form-select" name="category">
                                        <option value="Nature" <%= attraction.category === "Nature" ? "selected" : "" %>>Nature</option>
                                        <option value="Culture" <%= attraction.category === "Culture" ? "selected" : "" %>>Culture</option>
                                        <option value="Food" <%= attraction.category === "Food" ? "selected" : "" %>>Food</option>
                                        <option value="Entertainment" <%= attraction.category === "Entertainment" ? "selected" : "" %>>Entertainment</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control" name="description" rows="5" required><%= attraction.description %></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card large-panel h-100">
                            <div class="panel-header">
                                <h5 class="mb-1">Gallery & Images</h5>
                            </div>
                            <div class="panel-body">
                                <input type="hidden" name="currentImage1" value="<%= attraction.image1 %>">
                                <input type="hidden" name="currentImage2" value="<%= attraction.image2 %>">
                                <input type="hidden" name="currentImage3" value="<%= attraction.image3 %>">
                                <div class="row g-3 mb-4">
                                    <% if(attraction.image1) { %>
                                        <div class="col-4">
                                            <img src="/images/attractions/<%= attraction.image1 %>" class="img-fluid rounded" alt="Current image 1">
                                        </div>
                                    <% } %>
                                    <% if(attraction.image2) { %>
                                        <div class="col-4">
                                            <img src="/images/attractions/<%= attraction.image2 %>" class="img-fluid rounded" alt="Current image 2">
                                        </div>
                                    <% } %>
                                    <% if(attraction.image3) { %>
                                        <div class="col-4">
                                            <img src="/images/attractions/<%= attraction.image3 %>" class="img-fluid rounded" alt="Current image 3">
                                        </div>
                                    <% } %>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Upload New Image 1</label>
                                    <input type="file" class="form-control" name="image1" accept="image/*">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Upload New Image 2</label>
                                    <input type="file" class="form-control" name="image2" accept="image/*">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Upload New Image 3</label>
                                    <input type="file" class="form-control" name="image3" accept="image/*">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 text-center">
                        <button type="submit" class="btn btn-primary btn-lg px-5">Update Attraction</button>
                        <a href="/attractions" class="btn btn-secondary btn-lg ms-2">Back</a>
                    </div>
                </div>
            </form>
        <% } else { %>
            <div class="card large-panel text-center py-5">
                <h3 class="mb-3">No attraction found.</h3>
                <a href="/attractions" class="btn btn-primary">Back to Attractions</a>
            </div>
        <% } %>
    </main>
</body>
</html>