<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Attraction Details</title>
</head>

<body>
    <%- include("partials/header") %>

    <main class="container py-5">
        <% if(attraction) { %>
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <div class="card attraction-card overflow-hidden">
                        <img src="/images/attractions/<%= attraction.image1 %>" class="card-img-top" alt="<%= attraction.name %>">
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card large-panel h-100">
                        <div class="panel-header">
                            <h2 class="mb-2"><%= attraction.name %></h2>
                            <span class="badge bg-primary text-white"><%= attraction.category %></span>
                        </div>
                        <div class="panel-body">
                            <p class="text-muted mb-3"><strong>Location:</strong> <%= attraction.city %>, <%= attraction.country %></p>
                            <h5>About this attraction</h5>
                            <p class="text-muted"><%= attraction.description %></p>
                            <div class="row g-2 mt-4">
                                <div class="col-6">
                                    <img src="/images/attractions/<%= attraction.image2 %>" class="img-fluid rounded" alt="Gallery image 2">
                                </div>
                                <div class="col-6">
                                    <img src="/images/attractions/<%= attraction.image3 %>" class="img-fluid rounded" alt="Gallery image 3">
                                </div>
                            </div>
                            <div class="mt-4 d-flex flex-wrap gap-2">
                                <% if(user.role==="admin") { %>
                                    <a href="/updateAttraction/<%= attraction.attractionId %>" class="btn btn-secondary">Edit Attraction</a>
                                    <a href="/deleteAttraction/<%= attraction.attractionId %>" class="btn btn-warning">Delete</a>
                                <% } %>
                                <a href="/attractions" class="btn btn-primary">Back to Discover</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="card large-panel text-center py-5">
                <h3>Attraction not found.</h3>
            </div>
        <% } %>
    </main>
</body>
</html>