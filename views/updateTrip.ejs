<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>TripCanvas: Update Trip</title>
</head>

<body>
    <%- include('partials/header') %>
        <div class="container mt-4">
            <h2 class="text-center mb-4">
                Update Trip
            </h2>

            <% if (trip) { %>
                <form action="/updateTrip/<%= trip.tripId %>" method="POST" enctype="multipart/form-data"
                    class="mx-auto" style="max-width:500px;">
                    <div class="mb-3">
                        <label class="form-label">Trip Name</label>
                        <input type="text" class="form-control" name="tripName" value="<%= trip.tripName %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <input type="text" class="form-control" name="country" value="<%= trip.country %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" name="city" value="<%= trip.city %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" class="form-control" name="startDate"
                            value="<%= trip.startDate.toISOString().split('T')[0] %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" class="form-control" name="endDate"
                            value="<%= trip.endDate.toISOString().split('T')[0] %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Budget</label>
                        <input type="number" class="form-control" name="budget" step="0.01" value="<%= trip.budget %>"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <input type="text" class="form-control" name="status" value="<%= trip.status %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Current Images</label>

                        <input type="hidden" name="currentImage1" value="<%= trip.image1 %>">
                        <input type="hidden" name="currentImage2" value="<%= trip.image2 %>">
                        <input type="hidden" name="currentImage3" value="<%= trip.image3 %>">

                        <div class="row">
                            <% if (trip.image1) { %>
                                <div class="col">
                                    <img src="/images/trips/<%= trip.image1 %>" class="img-thumbnail" width="120">
                                </div>
                            <% } %>

                            <% if (trip.image2) { %>
                                <div class="col">
                                    <img src="/images/trips/<%= trip.image2 %>" class="img-thumbnail" width="120">
                                </div>
                            <% } %>

                            <% if (trip.image3) { %>
                                <div class="col">
                                    <img src="/images/trips/<%= trip.image3 %>" class="img-thumbnail" width="120">
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Upload New Images</label>
                        <input type="file" class="form-control" name="image1" accept="image/*">
                        <input type="file" class="form-control mt-2" name="image2" accept="image/*">
                        <input type="file" class="form-control mt-2" name="image3" accept="image/*">
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Update Trip</button>
                        <a href="/trips" class="btn btn-secondary">Back</a>
                    </div>
                </form>

                <% } else { %>
                    <p class="text-center">No trip found.</p>
                    <% } %>
        </div>
</body>

</html>