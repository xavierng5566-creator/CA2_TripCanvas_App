<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas: Update Trip</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title">Update Trip</h2>
            <p class="section-subtitle">Refine the details of your journey and refresh your itinerary visuals.</p>
        </div>

        <% if (trip) { %>
            <form action="/updateTrip/<%= trip.tripId %>" method="POST" enctype="multipart/form-data">
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card large-panel h-100">
                            <div class="panel-header">
                                <h5 class="mb-1">Destination Details</h5>
                            </div>
                            <div class="panel-body">
                                <div class="mb-3">
                                    <label class="form-label">Trip Name</label>
                                    <input type="text" class="form-control" name="tripName" value="<%= trip.tripName %>" required>
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Country</label>
                                        <input type="text" class="form-control" name="country" value="<%= trip.country %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" name="city" value="<%= trip.city %>" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card large-panel h-100">
                            <div class="panel-header">
                                <h5 class="mb-1">Travel Details</h5>
                            </div>
                            <div class="panel-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Start Date</label>
                                        <input type="date" class="form-control" name="startDate" value="<%= trip.startDate.toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">End Date</label>
                                        <input type="date" class="form-control" name="endDate" value="<%= trip.endDate.toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Budget</label>
                                        <input type="number" class="form-control" name="budget" step="0.01" value="<%= trip.budget %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Trip Status</label>
                                        <select class="form-select" name="status">
                                            <option value="Planning">Planning</option>
                                            <option value="Upcoming">Upcoming</option>
                                            <option value="Completed">Completed</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card large-panel">
                            <div class="panel-header">
                                <h5 class="mb-1">Trip Gallery</h5>
                                <p class="text-muted mb-0">Current images and replacement options.</p>
                            </div>
                            <div class="panel-body">
                                <input type="hidden" name="currentImage1" value="<%= trip.image1 %>">
                                <input type="hidden" name="currentImage2" value="<%= trip.image2 %>">
                                <input type="hidden" name="currentImage3" value="<%= trip.image3 %>">

                                <div class="row g-3 mb-4">
                                    <% if (trip.image1) { %>
                                        <div class="col-4">
                                            <img src="/images/trips/<%= trip.image1 %>" class="img-fluid rounded" alt="Current image 1">
                                        </div>
                                    <% } %>
                                    <% if (trip.image2) { %>
                                        <div class="col-4">
                                            <img src="/images/trips/<%= trip.image2 %>" class="img-fluid rounded" alt="Current image 2">
                                        </div>
                                    <% } %>
                                    <% if (trip.image3) { %>
                                        <div class="col-4">
                                            <img src="/images/trips/<%= trip.image3 %>" class="img-fluid rounded" alt="Current image 3">
                                        </div>
                                    <% } %>
                                </div>

                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Upload New Image 1</label>
                                        <input type="file" class="form-control" name="image1" accept="image/*">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Upload New Image 2</label>
                                        <input type="file" class="form-control" name="image2" accept="image/*">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Upload New Image 3</label>
                                        <input type="file" class="form-control" name="image3" accept="image/*">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 text-center">
                        <button type="submit" class="btn btn-primary btn-lg px-5">Update Trip</button>
                        <a href="/trips" class="btn btn-secondary btn-lg ms-2">Back</a>
                    </div>
                </div>
            </form>
        <% } else { %>
            <div class="card large-panel text-center py-5">
                <h3>No trip found.</h3>
            </div>
        <% } %>
    </main>
</body>

</html>