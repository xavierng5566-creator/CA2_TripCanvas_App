<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>TripCanvas</title>
</head>
<body>
    <%- include("partials/header") %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>Add New Plan</h2>
                <p class="text-muted"><%= trip.tripName %> • <%= trip.city %>, <%= trip.country %></p>
            </div>
            <a href="/planner/<%= trip.tripId %>" class="btn btn-secondary">Back to Planner</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form action="/planner/<%= trip.tripId %>/add" method="post">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Day</label>
                            <select class="form-select" name="dayNumber" required>
                                <option value="" disabled selected hidden>Select a day</option>
                                <% days.forEach((day) => { %>
                                    <option value="<%= day.dayNumber %>">
                                        Day <%= day.dayNumber %> of <%= days.length %> - <%= day.label %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Plan Title</label>
                            <input type="text" class="form-control" name="title" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Time</label>
                            <input type="text" class="form-control" name="timeSlot" placeholder="Morning / Evening">
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="description" rows="4"></textarea>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Save Plan</button>
                            <a href="/planner/<%= trip.tripId %>" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
