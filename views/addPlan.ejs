<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <title>TripCanvas</title>
</head>
<body>
    <%- include("partials/header") %>

    <main class="container py-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
            <div>
                <h2 class="section-title">Add New Plan</h2>
                <p class="section-subtitle"><%= trip.tripName %> • <%= trip.city %>, <%= trip.country %></p>
            </div>
            <a href="/planner/<%= trip.tripId %>" class="btn btn-secondary">Back to Planner</a>
        </div>

        <div class="card large-panel">
            <div class="panel-header">
                <h5 class="mb-0">Plan your day</h5>
            </div>
            <div class="panel-body">
                <form action="/planner/<%= trip.tripId %>/add" method="post">
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label">Day</label>
                            <select class="form-select" name="dayNumber" required>
                                <option value="" disabled selected hidden>Select a day</option>
                                <% days.forEach((day) => { %>
                                    <option value="<%= day.dayNumber %>">Day <%= day.dayNumber %> of <%= days.length %> - <%= day.label %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Plan Title</label>
                            <input type="text" class="form-control" name="title" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Time</label>
                            <input type="text" class="form-control" name="timeSlot" placeholder="Morning / Evening" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="description" rows="5" required></textarea>
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary">Save Plan</button>
                            <a href="/planner/<%= trip.tripId %>" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
