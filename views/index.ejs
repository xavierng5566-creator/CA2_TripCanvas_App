<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>

<body>
    <%- include('partials/header') %>

        <div class="container text-center">
            <% if (user) { %>
                <% if (user.role==="admin" ) { %>
                    <h2>Welcome Admin!</h2>
                    <a href="/adminDashboard">Go to Admin Dashboard</a>

                    <% } else { %>
                        <h2>Welcome back, <%= user.username %>!</h2>
                        <a href="/trips">View My Trips</a>

                        <% } %>
                            <% } else { %>
                                <h2>Welcome to TripCanvas</h2>
                                <p>Plan and organise your adventures the TripCanvas way!</p>

                                <a href="/login">Login to start planning</a>

                                <% } %>
        </div>
</body>
</html>