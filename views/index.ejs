<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>TripCanvas</title>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <section class="hero-panel mb-5">
            <img src="/images/miscellaneous/miscellaneous1.jpg" alt="Travel planning scene">
            <div class="hero-copy">
                <div class="hero-content col-lg-7">
                    <span class="badge bg-soft-blue text-white mb-3">Travel Smarter</span>
                    <h1>Organise trips, discover attractions, and manage packing with ease.</h1>
                    <p>TripCanvas helps travellers build personalised itineraries, discover destinations and keep packing on track from one dashboard.</p>
                    <div class="hero-actions d-flex flex-wrap gap-3 mt-4">
                        <% if (!user) { %>
                            <a href="/register" class="btn btn-primary btn-lg">Get Started</a>
                            <a href="/login" class="btn btn-secondary btn-lg">Login</a>
                        <% } else if (user.role === 'admin') { %>
                            <a href="/adminDashboard" class="btn btn-primary btn-lg">Open Admin Dashboard</a>
                            <a href="/trips" class="btn btn-secondary btn-lg">View Trips</a>
                        <% } else { %>
                            <a href="/trips" class="btn btn-primary btn-lg">View My Trips</a>
                            <a href="/attractions" class="btn btn-secondary btn-lg">Explore Attractions</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <section class="row gy-4">
            <div class="col-lg-6">
                <div class="feature-card card p-4 h-100">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <img src="/images/miscellaneous/miscellaneous2.jpg" class="rounded-4" alt="Trips" style="width:100px; height:100px; object-fit:cover;">
                        </div>
                        <div class="col">
                            <h3 class="section-title">Trip Management</h3>
                            <p class="section-subtitle mb-0">Create, update and organise every journey with clarity and confidence.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="feature-card card p-4 h-100">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <img src="/images/miscellaneous/miscellaneous3.jpg" class="rounded-4" alt="Planner" style="width:100px; height:100px; object-fit:cover;">
                        </div>
                        <div class="col">
                            <h3 class="section-title">Planner</h3>
                            <p class="section-subtitle mb-0">Build daily schedules, organise activities and always know what comes next.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="feature-card card p-4 h-100">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <img src="/images/miscellaneous/miscellaneous4.jpg" class="rounded-4" alt="Checklist" style="width:100px; height:100px; object-fit:cover;">
                        </div>
                        <div class="col">
                            <h3 class="section-title">Checklist</h3>
                            <p class="section-subtitle mb-0">Prepare packing essentials and track completion before every departure.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="feature-card card p-4 h-100">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <img src="/images/miscellaneous/miscellaneous5.jpg" class="rounded-4" alt="Attractions" style="width:100px; height:100px; object-fit:cover;">
                        </div>
                        <div class="col">
                            <h3 class="section-title">Attractions</h3>
                            <p class="section-subtitle mb-0">Discover destinations, explore places, and find inspiration for your next trip.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>